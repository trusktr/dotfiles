{
	"name": "classdiagram-ts",
	"displayName": "classdiagram-ts",
	"description": "create class diagram for typescript projects",
	"version": "0.1.40",
	"publisher": "AlexShen",
	"site": "https://shenz.visualstudio.com/",
	"engines": {
		"vscode": "^1.0.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"*"
	],
	"repository": "https://github.com/shenAwesome",
	"main": "./dist/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "tsd.showDiagram",
				"title": "Show Diagram",
				"icon": {
					"light": "resource/light/diagram.png",
					"dark": "resource/dark/diagram.png"
				}
			}
		],
		"menus": {
			"explorer/context": [
				{
					"when": "explorerResourceIsFolder",
					"command": "tsd.showDiagram",
					"group": "tsd"
				},
				{
					"when": "resourceLangId  == typescript || resourceLangId  == typescriptreact",
					"command": "tsd.showDiagram",
					"group": "tsd"
				}
			],
			"editor/title": [
				{
					"when": "resourceLangId  == typescript || resourceLangId  == typescriptreact",
					"command": "tsd.showDiagram",
					"group": "navigation"
				}
			]
		}
	},
	"scripts": {
		"vscode:prepublish": "webpack --mode production",
		"webpack": "webpack --mode development",
		"webpack-dev": "webpack --mode development --watch",
		"test-compile": "tsc -p ./"
	},
	"devDependencies": {
		"@types/find-up": "^4.0.0",
		"@types/glob": "^7.1.1",
		"@types/mocha": "^5.2.6",
		"@types/node": "^10.12.21",
		"@types/vscode": "^1.0.0",
		"glob": "^7.1.4",
		"mocha": "^6.1.4",
		"ts-loader": "^8.0.1",
		"tslint": "^5.12.1",
		"typescript": "^3.3.1",
		"vscode-test": "^1.0.2",
		"webpack": "^4.43.0",
		"webpack-cli": "^3.3.12"
	},
	"dependencies": {
		"@types/lodash": "^4.14.138",
		"chokidar": "^3.4.1",
		"find-up": "^4.1.0",
		"lodash": "^4.17.11",
		"recursive-readdir-sync": "^1.0.6",
		"reflect-metadata": "^0.1.13",
		"ts-morph": "^7.1.3"
	},
	"__metadata": {
		"id": "88a2b659-4503-4bad-ae9b-1b8c7f766c90",
		"publisherId": "b195ff95-7867-4b85-9b4f-d608bae5444e",
		"publisherDisplayName": "AlexShen"
	}
}